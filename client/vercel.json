{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://luxe-library-prod.eba-badmbjea.ap-south-1.elasticbeanstalk.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "http://luxe-library-prod.eba-badmbjea.ap-south-1.elasticbeanstalk.com/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
